def get_individual_tree_eval_path(
    model_name,
    train_data_name,
    test_data_name,
    param_id,
    device,
    timestamp,
    output_dir,
):
    path = build_log_path(
        model_name=model_name,
        train_data_name=train_data_name,
        test_data_name=test_data_name,
        param_id=param_id,
        device=device,
        timestamp=timestamp,
        log_name="tree_eval_logs",
        step_name="individual_tree_eval",
        output_dir=output_dir,
    )
    return f"{path}.csv"

def generate_individual_tree_eval_plot_paths(
    model_names,
    data_pairs,
    param_ids,
    device,
    timestamp,
    output_dir,
):
    eval_paths = [
        get_individual_tree_eval_path(
            model_name=model_name,
            train_data_name=train_data_name,
            test_data_name=test_data_name,
            param_id=param_id,
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )[:-4] + ".pdf"
        for model_name in model_names
        for train_data_name, test_data_name in data_pairs
        for param_id in param_ids
    ]
    return eval_paths


tree_eval_paths = generate_individual_tree_eval_plot_paths(
    model_names=model_names,
    data_pairs=data_pairs,
    param_ids=param_ids,
    device=device,
    timestamp=timestamp,
    output_dir=output_dir,
)


rule all:
    input:
        notebook_output_paths=notebook_output_paths if not evaluate_individual_trees else [],
        csv_output_path=csv_output_path if not evaluate_individual_trees else [],
        baseline_csv_output_path=baseline_csv_output_path if (baseline_model_list and not evaluate_individual_trees) else [],
        tree_eval_paths=tree_eval_paths if evaluate_individual_trees else [],


rule log_metadata_step:
    output:
        config_output_path=config_output_path,
        data_nicknames_output_path=data_nicknames_output_path,
    run:
        with open(output.config_output_path, "w") as f:
            yaml.dump(config, f, default_flow_style=False, sort_keys=False)
        shutil.copy(data_nicknames_path, output.data_nicknames_output_path)


rule optimize_hyperparameters_step:
    output:
        hyperparameter_path=get_model_params_json(
            model="{model_name}",
            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    benchmark:
        get_benchmark_path(
            rule_name="optimize_hyperparameters",
            model="{model_name}",
            train_data="{train_data_name}",
            test_data=None,
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
    run:
        if use_hyperparameter_optimize:
            optimize_hyperparameters(
                model_name=wildcards.model_name,
                data_name=wildcards.train_data_name,
                best_model_hparams_filepath=output.hyperparameter_path,
                device=device,
                profiling=False,
                n_trials=n_hyperparameter_trials,
                timestamp=timestamp,
                param_id=wildcards.param_id,
                output_dir=output_dir,
                data_nicknames_path=data_nicknames_path,
            )
        else:
            with open(output.hyperparameter_path, "w") as file:
                file.write(json.dumps(param_dicts[wildcards.param_id]))


rule train_model_step:
    input:
        hyperparameter_path=get_model_params_json(
            model="{model_name}",
            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    output:
        trained_model=get_trained_model_ckpt(
            model="{model_name}",
            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    benchmark:
        get_benchmark_path(
            rule_name="train_model",
            model="{model_name}",
            train_data="{train_data_name}",
            test_data=None,
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
    run:
        train_model(
            model_name=wildcards.model_name,
            data_name=wildcards.train_data_name,
            train_checkpoint=output.trained_model,
            device=device,
            hyperparameter_path=input.hyperparameter_path,
            profiling=False,
            timestamp=timestamp,
            param_id=wildcards.param_id,
            output_dir=output_dir,
            data_nicknames_path=data_nicknames_path,
        )


rule test_model_step:
    input:
        trained_model=get_trained_model_ckpt(
            model="{model_name}",
            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
        hyperparameter_path=get_model_params_json(
            model="{model_name}",
            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    output:
        tested_model=get_tested_model_ckpt(
            model="{model_name}",
            train_data="{train_data_name}",
            test_data="{test_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    benchmark:
        get_benchmark_path(
            rule_name="test_model",
            model="{model_name}",
            train_data="{train_data_name}",
            test_data="{test_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
    run:
        test_model(
            trained_model_name=wildcards.model_name,
            train_data_name=wildcards.train_data_name,
            trained_model_ckpt=input.trained_model,
            test_data_name=wildcards.test_data_name,
            test_checkpoint=output.tested_model,
            device=device,
            hyperparameter_path=input.hyperparameter_path,
            timestamp=timestamp,
            param_id=wildcards.param_id,
            output_dir=output_dir,
            data_nicknames_path=data_nicknames_path,
        )


rule create_csv_step:
    input:
        tested_model=get_tested_model_ckpt(
            model="{model_name}",
            train_data="{train_data_name}",
            test_data="{test_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
        trained_model=get_trained_model_ckpt(
            model="{model_name}",
            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
        hyperparameter_path=get_model_params_json(
            model="{model_name}",
            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    output:
        csv_path=get_csv_log_path(
            model_name="{model_name}",
            train_data_name="{train_data_name}",
            test_data_name="{test_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    wildcard_constraints:
        # Don't apply to baseline model
        model_name="(?!BaselineReversion).*"
    run:
        aggregate_data_to_csv(
            model_name=wildcards.model_name,
            train_data_name=wildcards.train_data_name,
            test_data_name=wildcards.test_data_name,
            device=device,
            timestamp=timestamp,
            param_id=wildcards.param_id,
            n_hyperparameter_trials=n_hyperparameter_trials,
            hyperparameter_path=input.hyperparameter_path,
            trained_model_ckpt=input.trained_model,
            tested_model_ckpt=input.tested_model,
            csv_output_path=output.csv_path,
            output_dir=output_dir,
        )


rule concat_csvs_step:
    input:
        csv_input_paths=csv_single_paths,
    output:
        csv_output_path=csv_output_path,
    run:
        concatenate_csvs(
            input_csv_paths=input.csv_input_paths,
            output_csv_path=output.csv_output_path,
        )


rule run_notebook_step:
    input:
        csv_output_path=csv_output_path,
        config_output_path=config_output_path,
        data_nicknames_output_path=data_nicknames_output_path,
        baseline_csv_output_path=baseline_csv_output_path if baseline_model_list else [],
    output:
        notebook_output_path=get_notebook_output_path(
            output_dir=run_dir,
            notebook_name="{notebook_name}",
        ),
    run:
        notebook_input_path = get_notebook_input_path(
            notebook_dict=notebook_dict,
            notebook_name=wildcards.notebook_name,
        )
        parameters = {
            "working_dir": working_dir,
            "output_dir": run_dir,
            "results_dir": f"{run_dir}/result_csvs_and_pdfs",
            "summary_csv_path": input.csv_output_path,
            "config_path": input.config_output_path,
            "data_nicknames_path": input.data_nicknames_output_path,
        }

        try:
            pm.execute_notebook(
                input_path=notebook_input_path,
                output_path=output.notebook_output_path,
                parameters=parameters,
                report_mode=False,
            )
        except Exception as e:
            print(f"Notebook execution failed: {e}")


rule test_baseline_model_step:
    output:
        result_path=get_baseline_result_path(
            model_name="{model_name}",
            test_data_name="{test_data_name}",
            timestamp=timestamp,
            output_dir=output_dir,
        )
    run:
        test_baseline_model(
            model_name=wildcards.model_name,
            test_data_name=wildcards.test_data_name,
            result_path=output.result_path,
            timestamp=timestamp,
            output_dir=output_dir,
            data_nicknames_path=data_nicknames_path,
        )


rule create_baseline_csv_step:
    input:
        result_path=get_baseline_result_path(
            model_name="{model_name}",
            test_data_name="{test_data_name}",
            timestamp=timestamp,
            output_dir=output_dir,
        )
    output:
        csv_path=get_csv_log_path(
            model_name="{model_name}",
            train_data_name=None,
            test_data_name="{test_data_name}",
            param_id=None,
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
    wildcard_constraints:
        # Only apply to baseline model
        model_name="BaselineReversion"
    run:
        aggregate_baseline_data_to_csv(
            model_name=wildcards.model_name,
            test_data_name=wildcards.test_data_name,
            timestamp=timestamp,
            result_path=input.result_path,
            csv_output_path=output.csv_path,
            output_dir=output_dir,
        )

rule concat_baseline_csvs_step:
    input:
        csv_input_paths=baseline_csv_paths,
    output:
        csv_output_path=baseline_csv_output_path,
    run:
        concatenate_csvs(
            input_csv_paths=input.csv_input_paths,
            output_csv_path=output.csv_output_path,
        )
