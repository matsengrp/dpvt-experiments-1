  'n_hyperparameter_trials': 100,
  'cross_datasets': False,
  'output_dir': "_output",

  # if hyperparameter_optimize is False, then uses hyperparameter arguments below.
  'hyperparameter_optimize': True,
  'hyperparameters': {
      'learning_rate': [0.0002, 0.0004],
      'batch_size': [512],
      'accum_grad_batches': [1],
      'epochs': [100, 200],
      'feature_length': [128],
      'dim_mlp_layers': [256],
  },
