import sys
from datetime import datetime

snakefile_dir = workflow.basedir
sys.path.append(snakefile_dir + "/..")

from dpvtex.dpvt_zoo import (
    train_model,
    test_model,
    trained_model_path,
    tested_model_path,
    best_model_params_path,
    optimize_hyperparameters,
    csv_log_path,
    generate_csv_log_paths,
    aggregate_data_to_csv
)

default_config = {
  'models': None,
  'train_data_names': None,
  'test_data_names': None,
  'device': 'cpu',
  'timestamp': str(datetime.now().strftime("%Y-%m-%d")),
  'n_hyperparameter_trials': 10,
}

config_path = os.path.join(snakefile_dir, "config.yaml")
configfile: config_path

for arg in default_config:
    if arg not in config:
        config[arg] = default_config[arg]

model_names = config["models"]
train_data_names = config["train_data"]
test_data_names = config["test_data"]
device = config["device"]
timestamp=config["timestamp"]
n_hyperparameter_trials = int(config["n_hyperparameter_trials"])
data_pairs = list(zip(train_data_names, test_data_names))

def generate_tested_model_ckpts(model_names, data_pairs):
    tested_model_ckpts = [
        tested_model_ckpt(model_name, train_data_name, test_data_name)
        for model_name in model_names
        for train_data_name, test_data_name in data_pairs
    ]
    # print(f'TESTED_MODEL_CKPTS:\n{tested_model_ckpts}')
    return tested_model_ckpts


def trained_model_ckpt(model, data):
    return f"{trained_model_path(model, data)}.ckpt"


def tested_model_ckpt(model, train_data, test_data):
    return f"{tested_model_path(model, train_data, test_data)}.ckpt"


def best_model_params(model, data):
    return f"{best_model_params_path(model, data)}.json"


rule all:
    input:
        generate_tested_model_ckpts(model_names, data_pairs),
        generate_csv_log_paths(model_names, data_pairs, device=device, date=timestamp),
        # csv_log_path(model_names, data_pairs, device=device, date=timestamp, is_final=True),


rule train_models:
    input:
        hyperparameter_path=best_model_params("{model_name}", "{train_data_name}"),
    output:
        trained_model=trained_model_ckpt("{model_name}", "{train_data_name}"),
    benchmark:
        "benchmarks/train_model/{model_name}_{train_data_name}_" + device + ".tsv"
    run:
        train_model(
            wildcards.model_name,
            wildcards.train_data_name,
            output.trained_model,
            device,
            input.hyperparameter_path,
            profiling=False,
        )


rule test_models:
    input:
        trained_model=trained_model_ckpt("{model_name}", "{train_data_name}"),
        hyperparameter_path=best_model_params("{model_name}", "{train_data_name}"),
    output:
        tested_model=tested_model_ckpt(
            "{model_name}", "{train_data_name}", "{test_data_name}"
        ),
    run:
        test_model(
            trained_model_name=wildcards.model_name,
            train_data_name=wildcards.train_data_name,
            trained_model_ckpt=input.trained_model,
            test_data_name=wildcards.test_data_name,
            test_checkpoint=output.tested_model,
            device=device,
            hyperparameter_path=input.hyperparameter_path,
        )


rule hyperparameter_optimization:
    output:
        best_model_params=best_model_params("{model_name}", "{train_data_name}"),
    run:
        optimize_hyperparameters(
            model_name=wildcards.model_name,
            data_name=wildcards.train_data_name,
            best_model_hparams_filepath=output.best_model_params,
            device=device,
            profiling=False,
            n_trials=n_hyperparameter_trials
        )

rule create_csvs_and_pdfs:
    input:
        tested_model=tested_model_ckpt("{model_name}", "{train_data_name}", "{test_data_name}"),
        trained_model=trained_model_ckpt("{model_name}", "{train_data_name}"),
        hyperparameter_path=best_model_params("{model_name}", "{train_data_name}"),
    output:
        csv_path=csv_log_path("{model_name}", "{train_data_name}", test_data_name="{test_data_name}", device="{device}", date="{timestamp}"),
        # csv_final_path=csv_log_path("{model_name}", "{train_data_name}", test_data_name="{test_data_name}", device="{device}", date="{timestamp}"),
    run:
        aggregate_data_to_csv(
          model_name=wildcards.model_name,
          train_data_name=wildcards.train_data_name,
          test_data_name=wildcards.test_data_name,
          device=device,
          timestamp=timestamp,
          n_hyperparameter_trials=n_hyperparameter_trials,
          hyperparameter_path=input.hyperparameter_path,
          trained_model_ckpt=input.trained_model,
          tested_model_ckpt=input.tested_model,
          csv_outpath=output.csv_path,
        )

