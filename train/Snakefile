def generate_data_pairs(train_data_names, test_data_names, use_cross_datasets):
    if not use_cross_datasets:
        data_pairs = list(zip(train_data_names, test_data_names))
    else:
        data_pairs = [x for x in itertools.product(train_data_names, test_data_names)]
    return data_pairs


def generate_model_params_jsons(
    model_names, train_data_names, param_ids, device, timestamp, output_dir
):
    return [
        get_model_params_json(
            model=model_name,
            train_data=train_data_name,
            param_id=param_id,
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
        for model_name in model_names
        for train_data_name in train_data_names
        for param_id in param_ids
    ]


def generate_trained_model_ckpts(
    model_names, train_data_names, param_ids, device, timestamp, output_dir
):
    return [
        get_trained_model_ckpt(
            model=model_name,
            train_data=train_data_name,
            param_id=param_id,
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
        for model_name in model_names
        for train_data_name in train_data_names
        for param_id in param_ids
    ]


def generate_tested_model_ckpts(
    model_names, data_pairs, param_ids, device, timestamp, output_dir
):
    return [
        get_tested_model_ckpt(
            model=model_name,
            train_data=train_data_name,
            test_data=test_data_name,
            param_id=param_id,
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
        for model_name in model_names
        for train_data_name, test_data_name in data_pairs
        for param_id in param_ids
    ]


def get_trained_model_ckpt(model, train_data, param_id, device, timestamp, output_dir):
    path = get_trained_model_path(
        model, train_data, param_id, device, timestamp, output_dir
    )
    return f"{path}.ckpt"


def get_tested_model_ckpt(
    model, train_data, test_data, param_id, device, timestamp, output_dir
):
    path = get_tested_model_path(
        model, train_data, test_data, param_id, device, timestamp, output_dir
    )
    return f"{path}.ckpt"


def get_model_params_json(model, train_data, param_id, device, timestamp, output_dir):
    path = get_model_params_path(
        model, train_data, param_id, device, timestamp, output_dir
    )
    return f"{path}.json"


def get_benchmark_path(
    rule_name,
    model,
    train_data,
    test_data,
    param_id,
    device,
    timestamp,
    output_dir,
):
    path = build_log_path(
        model_name=model,
        train_data_name=train_data,
        test_data_name=test_data,
        param_id=param_id,
        device=device,
        timestamp=timestamp,
        log_name="benchmark_logs",
        step_name=rule_name,
        output_dir=output_dir,
    )
    return f"{path}.tsv"


def generate_hyperparameter_dicts(hyperparameters, use_hyperparameter_optimize):
    if use_hyperparameter_optimize:
        return ["ParamOpt"], {}

    param_dicts = {}
    keys = hyperparameters.keys()
    values = [x for x in hyperparameters.values()]
    for id, combination in enumerate(itertools.product(*values)):
        param_id = f"Param{id}"
        result_dict = dict(zip(keys, combination))
        param_dicts[param_id] = result_dict
    return list(param_dicts.keys()), param_dicts


def get_csv_log_path(
    model_name,
    train_data_name,
    test_data_name,
    param_id,
    timestamp,
    device,
    output_dir,
):
    path = build_log_path(
        model_name=model_name,
        train_data_name=train_data_name,
        test_data_name=test_data_name,
        param_id=param_id,
        device=device,
        timestamp=timestamp,
        log_name="csv_logs",
        step_name="",
        output_dir=output_dir,
    )
    return f"{path}.csv"


def generate_csv_log_paths(
    model_names,
    data_pairs,
    param_ids,
    device,
    timestamp,
    output_dir,
):
    csv_log_paths = [
        get_csv_log_path(
            model_name=model_name,
            train_data_name=train_data_name,
            test_data_name=test_data_name,
            param_id=param_id,
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        )
        for model_name in model_names
        for train_data_name, test_data_name in data_pairs
        for param_id in param_ids
    ]
    return csv_log_paths


