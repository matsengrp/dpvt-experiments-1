train_data_names = config["train_data"]
test_data_names = config["test_data"]
device = config["device"]
timestamp = config["timestamp"]
n_hyperparameter_trials = config["n_hyperparameter_trials"]
use_cross_datasets = config["use_cross_datasets"]
use_hyperparameter_optimize = config["use_hyperparameter_optimize"]
