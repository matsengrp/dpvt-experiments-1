import sys

snakefile_dir = workflow.basedir
sys.path.append(snakefile_dir + "/..")

from dpvtex.dpvt_zoo import (
    train_model, 
    trained_model_path, 
    best_model_params_path, 
    optimize_hyperparameters,
)

config_path = os.path.join(snakefile_dir, "config.yaml")
configfile: config_path

model_names = config["models"]
data_names = config["data"]


def trained_model_ckpt(model_name, data_name):
    return f"{trained_model_path(model_name, data_name)}.ckpt"

def tested_model_ckpt(model_name, data_name):
    return f"{trained_model_path(model_name, data_name)}_test.ckpt"

def best_model_params(model_name, data_name):
    return f"{best_model_params_path(model_name, data_name)}.json"


rule all:
    input:
        expand(trained_model_ckpt("{model_name}", "{data_name}"),
            model_name=model_names,
            data_name=data_names)


rule train_model:
    input:
        best_model_params("{model_name}", "{data_name}")
    output:
        trained_model=trained_model_ckpt("{model_name}", "{data_name}"),
        test_checkpoint=tested_model_ckpt("{model_name}", "{data_name}")
    run:
        train_model(
            wildcards.model_name, 
            wildcards.data_name, 
            output.trained_model, 
            output.test_checkpoint
        )


rule hyperparameter_optimization:
    output:
        best_model_params=best_model_params("{model_name}", "{data_name}")
    run:
        optimize_hyperparameters(wildcards.model_name, wildcards.data_name, output.best_model_params)
