# use defaults where option not in config file
for arg in default_config:
    if arg not in config:
        config[arg] = default_config[arg]
for arg in default_config['hyperparameters']:
    if arg not in config['hyperparameters']:
        config['hyperparameters'][arg] = default_config['hyperparameters'][arg]


# config settings
output_dir = config["output_dir"]
model_names = config["models"]
train_data_names = config["train_data"]
test_data_names = config["test_data"]
device = config["device"]
timestamp=config["timestamp"]
n_hyperparameter_trials = config["n_hyperparameter_trials"]
use_cross_datasets = config["cross_datasets"]
use_hyperparameter_optimize = config["hyperparameter_optimize"]
hyperparameters = config["hyperparameters"]


def generate_data_pairs(train_data_names, test_data_names, use_cross_datasets=False):
    if not use_cross_datasets:
        data_pairs = list(zip(train_data_names, test_data_names))
    else:
        data_pairs = [x for x in itertools.product(train_data_names, test_data_names)]
    return data_pairs


def generate_trained_model_ckpts(model_names, train_data_names, param_ids=[None]):
    return [
        trained_model_ckpt(model_name, train_data_name, param_id)
        for model_name in model_names
        for train_data_name in train_data_names
        for param_id in param_ids
    ]


def generate_tested_model_ckpts(model_names, data_pairs, param_ids=[None]):
    return [
        tested_model_ckpt(model_name, train_data_name, test_data_name, param_id)
        for model_name in model_names
        for train_data_name, test_data_name in data_pairs
        for param_id in param_ids
    ]


def trained_model_ckpt(model, data, param_id=None):
    path = f"{trained_model_path(model, data, param_id)}"
    return f"{path}.ckpt"


def tested_model_ckpt(model, train_data, test_data, param_id=None):
    path = f"{tested_model_path(model, train_data, test_data, param_id)}"
    return f"{path}.ckpt"


def best_model_params(model, data, param_id=None):
    path = f"{best_model_params_path(model, data, param_id)}"
    return f"{path}.json"


def benchmark_path(rule_name, model, train_data, test_data=None, device=None, param_id=None):
    path = f"benchmarks/{rule_name}/{device}_{model_str(model, train_data, test_data_name=test_data, param_id=param_id)}"
    return f"{path}.tsv"


def generate_hyperparameter_dicts(hyperparameters, use_hyperparameter_optimize):
    if use_hyperparameter_optimize:
        return ["ParamOpt"], {}

    param_dicts = {}
    keys = hyperparameters.keys()
    values = [x for x in hyperparameters.values()]
    for id, combination in enumerate(itertools.product(*values)):
        param_id = f"Param{id}"
        result_dict = dict(zip(keys, combination))
        param_dicts[param_id] = result_dict
    return list(param_dicts.keys()), param_dicts

def csv_log_path(
    model_name, train_data_name, test_data_name=None, device=None, date=None, param_id=None,
):
    path = f"result_csvs_and_pdfs/{device}_{date}"
    path = f"{path}/{model_str(model_name, train_data_name, test_data_name, param_id)}.csv"
    return path


def generate_csv_log_paths(model_names, data_pairs, device, date=None, param_ids=[None]):
    csv_log_paths = []
    for model_name in model_names:
        for train_data_name, test_data_name in data_pairs:
            for param_id in param_ids:
                csv_log_paths.append(
                    csv_log_path(
                        model_name,
                        train_data_name,
                        test_data_name=test_data_name,
                        device=device,
                        date=date,
                        param_id=param_id,
                    )
                )
    return csv_log_paths


# rule input/output paths
data_pairs = generate_data_pairs(train_data_names, test_data_names, use_cross_datasets)
param_ids, param_dicts = generate_hyperparameter_dicts(hyperparameters, use_hyperparameter_optimize)
tested_model_chkpts = generate_tested_model_ckpts(model_names, data_pairs, param_ids)
trained_model_chkpts = generate_trained_model_ckpts(model_names, train_data_names, param_ids)
csv_individual_paths = generate_csv_log_paths(model_names, data_pairs, device, param_ids=param_ids, date=timestamp)
csv_output_path = f"result_csvs_and_pdfs/FINAL.csv"
notebook_input_path = f"plot_final_csv.input.ipynb"
notebook_output_path = f"result_csvs_and_pdfs/plot_final_csv.ipynb"


