# ==============================================================================
# Imports
# ==============================================================================

import sys, os, shutil
from datetime import datetime
import itertools
import pprint as pp
import json, yaml
from pathlib import Path

from dpvtex.dpvt_zoo import (
    get_model_str,
    build_log_path,
    get_trained_model_path,
    get_tested_model_path,
    get_model_params_path,
    get_baseline_result_path,
    train_model,
    test_model,
    optimize_hyperparameters,
    aggregate_data_to_csv,
    concatenate_csvs,
    test_baseline_model,
    aggregate_baseline_data_to_csv,
)
from dpvtex.plotting import generate_summary_plots, LabelConfig
from plot_times import generate_benchmark_plots


# ==============================================================================
# Configuration
# ==============================================================================

snakefile_dir = workflow.basedir
sys.path.append(f"{snakefile_dir}/..")
default_config_path = os.path.join(snakefile_dir, "config.yaml")
if not config:

    configfile: default_config_path


default_config = {
    "working_dir": os.getcwd(),
    "start_time": str(datetime.now().strftime("%Y-%m-%d_%H:%M:%S")),
    "output_dir": "_output",
    "data_nicknames_path": "data_nicknames.json",
    "models": ["TraverseNN"],
    "train_data": ["FourLeafTrain"],
    "test_data": ["FourLeafTest"],
    "device": "cpu",
    "timestamp": str(datetime.now().strftime("%Y-%m-%d")),
    "n_hyperparameter_trials": 100,
    "use_cross_datasets": False,
    "use_hyperparameter_optimize": True,
    "profiling": False,
    "write_benchmarks": True,
    "seed": None,
    "hyperparameters": {
        "learning_rate": [0.0002, 0.0004],
        "batch_size": [512],
        "accum_grad_batches": [1],
        "epochs": [100, 200],
        "feature_length": [128],
        "dim_mlp_layers": [256],
    },
}


# use defaults where option not in config file
for arg in default_config:
    if arg not in config:
        config[arg] = default_config[arg]
for arg in default_config["hyperparameters"]:
    if arg not in config["hyperparameters"]:
        config["hyperparameters"][arg] = default_config["hyperparameters"][arg]
if not config["use_hyperparameter_optimize"]:
    config["n_hyperparameter_trials"] = 0


# config settings
working_dir = config["working_dir"]
output_dir = config["output_dir"]
data_nicknames_path = config["data_nicknames_path"]
model_names = config["models"]
train_data_names = config["train_data"]
test_data_names = config["test_data"]
device = config["device"]
timestamp = config["timestamp"]
n_hyperparameter_trials = config["n_hyperparameter_trials"]
use_cross_datasets = config["use_cross_datasets"]
use_hyperparameter_optimize = config["use_hyperparameter_optimize"]
profiling = config["profiling"]
write_benchmarks = config["write_benchmarks"]
seed = config["seed"]
hyperparameters = config["hyperparameters"]
label_config = (
    LabelConfig(**config["label_config"]) if "label_config" in config else None
)
plot_details = False  # set to True to plot more training/testing stats

# Common context for path generation
ctx = {"device": device, "timestamp": timestamp, "output_dir": output_dir}


# ==============================================================================
# Helper Functions
# ==============================================================================


def generate_data_pairs(train_data_names, test_data_names, use_cross_datasets):
    if not use_cross_datasets:
        return list(zip(train_data_names, test_data_names))
    return list(itertools.product(train_data_names, test_data_names))


def get_path_with_ext(path_func, ext, model, train_data, param_id, test_data=None):
    """Unified path wrapper that adds file extension."""
    if test_data is not None:
        path = path_func(model, train_data, test_data, param_id, **ctx)
    else:
        path = path_func(model, train_data, param_id, **ctx)
    return f"{path}.{ext}"


def get_trained_model_ckpt(model, train_data, param_id):
    return get_path_with_ext(
        get_trained_model_path, "ckpt", model, train_data, param_id
    )


def get_tested_model_ckpt(model, train_data, test_data, param_id):
    return get_path_with_ext(
        get_tested_model_path, "ckpt", model, train_data, param_id, test_data
    )


def get_model_params_json(model, train_data, param_id):
    return get_path_with_ext(get_model_params_path, "json", model, train_data, param_id)


def get_benchmark_path(rule_name, model, train_data, test_data, param_id):
    path = build_log_path(
        model_name=model,
        train_data_name=train_data,
        test_data_name=test_data,
        param_id=param_id,
        log_name="benchmark_logs",
        step_name=rule_name,
        **ctx,
    )
    return f"{path}.tsv"


def get_csv_log_path(model_name, train_data_name, test_data_name, param_id):
    path = build_log_path(
        model_name=model_name,
        train_data_name=train_data_name,
        test_data_name=test_data_name,
        param_id=param_id,
        log_name="csv_logs",
        step_name="",
        **ctx,
    )
    return f"{path}.csv"


def generate_hyperparameter_dicts(hyperparameters, use_hyperparameter_optimize):
    if use_hyperparameter_optimize:
        return ["ParamOpt"], {}

    param_dicts = {}
    for id, combination in enumerate(itertools.product(*hyperparameters.values())):
        param_id = f"Param{id}"
        param_dicts[param_id] = dict(zip(hyperparameters.keys(), combination))
    return list(param_dicts.keys()), param_dicts


def generate_paths(path_func, model_names, data_pairs, param_ids):
    """Generic path generator for model/data/param combinations."""
    return [
        path_func(model_name, train_data, test_data, param_id)
        for model_name in model_names
        for train_data, test_data in data_pairs
        for param_id in param_ids
    ]


def generate_train_paths(path_func, model_names, train_data_names, param_ids):
    """Path generator for training (no test data)."""
    return [
        path_func(model_name, train_data, param_id)
        for model_name in model_names
        for train_data in train_data_names
        for param_id in param_ids
    ]


# ------------------------------------------------------------------------------
# Wildcard Helpers (for use in rule definitions)
# ------------------------------------------------------------------------------


def wildcard_params_json():
    return get_model_params_json("{model_name}", "{train_data_name}", "{param_id}")


def wildcard_trained_ckpt():
    return get_trained_model_ckpt("{model_name}", "{train_data_name}", "{param_id}")


def wildcard_tested_ckpt():
    return get_tested_model_ckpt(
        "{model_name}", "{train_data_name}", "{test_data_name}", "{param_id}"
    )


def wildcard_benchmark(rule_name, with_test_data=False):
    test_data = "{test_data_name}" if with_test_data else None
    return get_benchmark_path(
        rule_name, "{model_name}", "{train_data_name}", test_data, "{param_id}"
    )


def wildcard_csv_log(with_test_data=True):
    test_data = "{test_data_name}" if with_test_data else None
    return get_csv_log_path(
        "{model_name}", "{train_data_name}", test_data, "{param_id}"
    )


# ==============================================================================
# Path Generation
# ==============================================================================
data_pairs = generate_data_pairs(train_data_names, test_data_names, use_cross_datasets)
param_ids, param_dicts = generate_hyperparameter_dicts(
    hyperparameters=hyperparameters,
    use_hyperparameter_optimize=use_hyperparameter_optimize,
)


# create trained_model_list containing only trainable model, not baseline models
baseline_models = ["BaselineReversion"]
trained_models = [model for model in model_names if model not in baseline_models]
baseline_model_list = [model for model in model_names if model in baseline_models]

# Generate paths for trained models only
model_param_jsons = generate_train_paths(
    get_model_params_json, trained_models, train_data_names, param_ids
)
trained_model_ckpts = generate_train_paths(
    get_trained_model_ckpt, trained_models, train_data_names, param_ids
)

baseline_result_paths = [
    get_baseline_result_path(model_name, test_data_name, timestamp, output_dir)
    for model_name in baseline_model_list
    for test_data_name in test_data_names
]

# Generate paths for CSV files from baseline models
baseline_csv_paths = [
    get_csv_log_path(model_name, None, test_data_name, None)
    for model_name in baseline_model_list
    for test_data_name in test_data_names
]
tested_model_ckpts = generate_paths(
    get_tested_model_ckpt, trained_models, data_pairs, param_ids
)
csv_single_paths = generate_paths(
    get_csv_log_path, trained_models, data_pairs, param_ids
)

run_dir = f"{working_dir}/{output_dir}/run.{timestamp}"
csv_output_path = f"{run_dir}/result_csvs_and_pdfs/summary.csv"
baseline_csv_output_path = f"{run_dir}/result_csvs_and_pdfs/baseline_summary.csv"
config_output_path = f"{run_dir}/result_csvs_and_pdfs/config.yaml"
data_nicknames_output_path = f"{run_dir}/result_csvs_and_pdfs/data_nicknames.json"

# Benchmark paths for timing plots
train_benchmark_paths = [
    get_benchmark_path("train_model", model_name, train_data_name, None, param_id)
    for model_name in trained_models
    for train_data_name in train_data_names
    for param_id in param_ids
]
test_benchmark_paths = [
    get_benchmark_path(
        "test_model", model_name, train_data_name, test_data_name, param_id
    )
    for model_name in trained_models
    for train_data_name, test_data_name in data_pairs
    for param_id in param_ids
]
all_benchmark_paths = train_benchmark_paths + test_benchmark_paths
timing_plots_dir = f"{run_dir}/timing_plots"
timing_plots_output = f"{timing_plots_dir}/training_times.pdf"

# Summary plots output path (replaces notebook-based plotting)
summary_plots_output = f"{run_dir}/result_csvs_and_pdfs/test_auroc_heatmap.pdf"


# ==============================================================================
# Rules
# ==============================================================================


rule all:
    input:
        summary_plots=summary_plots_output,
        csv_output_path=csv_output_path,
        baseline_csv_output_path=baseline_csv_output_path if baseline_model_list else [],
        timing_plot=timing_plots_output if write_benchmarks else [],


rule log_metadata:
    output:
        config_output_path=config_output_path,
        data_nicknames_output_path=data_nicknames_output_path,
    run:
        with open(output.config_output_path, "w") as f:
            yaml.dump(config, f, default_flow_style=False, sort_keys=False)
        shutil.copy(data_nicknames_path, output.data_nicknames_output_path)


rule optimize_hyperparameters:
    output:
        hyperparameter_path=wildcard_params_json(),
    benchmark:
        wildcard_benchmark("optimize_hyperparameters")
    run:
        if use_hyperparameter_optimize:
            optimize_hyperparameters(
                model_name=wildcards.model_name,
                data_name=wildcards.train_data_name,
                best_model_hparams_filepath=output.hyperparameter_path,
                device=device,
                profiling=False,
                n_trials=n_hyperparameter_trials,
                timestamp=timestamp,
                param_id=wildcards.param_id,
                output_dir=output_dir,
                data_nicknames_path=data_nicknames_path,
            )
        else:
            with open(output.hyperparameter_path, "w") as file:
                file.write(json.dumps(param_dicts[wildcards.param_id]))


rule train_model:
    input:
        hyperparameter_path=wildcard_params_json(),
    output:
        trained_model=wildcard_trained_ckpt(),
    benchmark:
        wildcard_benchmark("train_model")
    run:
        train_model(
            model_name=wildcards.model_name,
            data_name=wildcards.train_data_name,
            train_checkpoint=output.trained_model,
            device=device,
            hyperparameter_path=input.hyperparameter_path,
            profiling=profiling,
            timestamp=timestamp,
            param_id=wildcards.param_id,
            output_dir=output_dir,
            data_nicknames_path=data_nicknames_path,
            seed=seed,
        )


rule test_model:
    input:
        trained_model=wildcard_trained_ckpt(),
        hyperparameter_path=wildcard_params_json(),
    output:
        tested_model=wildcard_tested_ckpt(),
    benchmark:
        wildcard_benchmark("test_model", with_test_data=True)
    shell:
        """
        python -c "from dpvtex.dpvt_zoo import test_model; test_model(
            trained_model_name='{wildcards.model_name}',
            train_data_name='{wildcards.train_data_name}',
            trained_model_ckpt='{input.trained_model}',
            test_data_name='{wildcards.test_data_name}',
            test_checkpoint='{output.tested_model}',
            device='{device}',
            hyperparameter_path='{input.hyperparameter_path}',
            profiling={profiling},
            timestamp='{timestamp}',
            param_id='{wildcards.param_id}',
            output_dir='{output_dir}',
            data_nicknames_path='{data_nicknames_path}',
        )"
        """


rule create_csv:
    input:
        tested_model=wildcard_tested_ckpt(),
        trained_model=wildcard_trained_ckpt(),
        hyperparameter_path=wildcard_params_json(),
    output:
        csv_path=wildcard_csv_log(),
    wildcard_constraints:
        # Don't apply to baseline model
        model_name="(?!BaselineReversion).*",
    run:
        aggregate_data_to_csv(
            model_name=wildcards.model_name,
            train_data_name=wildcards.train_data_name,
            test_data_name=wildcards.test_data_name,
            device=device,
            timestamp=timestamp,
            param_id=wildcards.param_id,
            n_hyperparameter_trials=n_hyperparameter_trials,
            hyperparameter_path=input.hyperparameter_path,
            trained_model_ckpt=input.trained_model,
            tested_model_ckpt=input.tested_model,
            csv_output_path=output.csv_path,
            output_dir=output_dir,
        )


rule concat_csvs:
    input:
        csv_input_paths=csv_single_paths,
    output:
        csv_output_path=csv_output_path,
    run:
        concatenate_csvs(
            input_csv_paths=input.csv_input_paths,
            output_csv_path=output.csv_output_path,
        )


rule generate_summary_plots:
    input:
        csv_output_path=csv_output_path,
        config_output_path=config_output_path,
        data_nicknames_output_path=data_nicknames_output_path,
        baseline_csv_output_path=baseline_csv_output_path if baseline_model_list else [],
    output:
        summary_plots=summary_plots_output,
    run:
        generate_summary_plots(
            summary_csv_path=input.csv_output_path,
            results_dir=f"{run_dir}/result_csvs_and_pdfs",
            config_path=input.config_output_path,
            data_nicknames_path=input.data_nicknames_output_path,
            baseline_csv_path=(
                input.baseline_csv_output_path if baseline_model_list else None
            ),
            working_dir=working_dir,
            plot_details=plot_details,
            label_config=label_config,
        )


rule test_baseline_model:
    output:
        result_path=get_baseline_result_path(
            "{model_name}", "{test_data_name}", timestamp, output_dir
        ),
    run:
        test_baseline_model(
            model_name=wildcards.model_name,
            test_data_name=wildcards.test_data_name,
            result_path=output.result_path,
            timestamp=timestamp,
            output_dir=output_dir,
            data_nicknames_path=data_nicknames_path,
        )


rule create_baseline_csv:
    input:
        result_path=get_baseline_result_path(
            "{model_name}", "{test_data_name}", timestamp, output_dir
        ),
    output:
        csv_path=get_csv_log_path("{model_name}", None, "{test_data_name}", None),
    wildcard_constraints:
        # Only apply to baseline model
        model_name="BaselineReversion",
    run:
        aggregate_baseline_data_to_csv(
            model_name=wildcards.model_name,
            test_data_name=wildcards.test_data_name,
            timestamp=timestamp,
            result_path=input.result_path,
            csv_output_path=output.csv_path,
            output_dir=output_dir,
        )


rule concat_baseline_csvs:
    input:
        csv_input_paths=baseline_csv_paths,
    output:
        csv_output_path=baseline_csv_output_path,
    run:
        concatenate_csvs(
            input_csv_paths=input.csv_input_paths,
            output_csv_path=output.csv_output_path,
        )


rule plot_times:
    input:
        trained_models=trained_model_ckpts,
        tested_models=tested_model_ckpts,
    output:
        timing_plot=timing_plots_output,
    run:
        generate_benchmark_plots(
            models=trained_models,
            train_data_names=train_data_names,
            test_data_names=test_data_names,
            benchmark_dir=f"{run_dir}/benchmark_logs",
            output_dir=timing_plots_dir,
            nicknames_path=data_nicknames_path,
            profiler_dir=f"{run_dir}/preprocessing_times",
        )
