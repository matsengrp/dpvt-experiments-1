rule hyperparameter_optimization:
    output:
        hyperparameter_path=best_model_params("{model_name}", "{train_data_name}", param_id="{param_id}"),
    benchmark:
        benchmark_path("hyperparameter_optimization", "{model_name}", train_data="{train_data_name}", device=device, param_id="{param_id}"),
    run:
        if use_hyperparameter_optimize:
            optimize_hyperparameters(
                model_name=wildcards.model_name,
                data_name=wildcards.train_data_name,
                best_model_hparams_filepath=output.hyperparameter_path,
                device=device,
                profiling=False,
                n_trials=n_hyperparameter_trials
            )
        else:
            with open(output.hyperparameter_path, 'w') as file:
                file.write(json.dumps(param_dicts[wildcards.param_id]))


rule train_models:
    input:
        hyperparameter_path=best_model_params("{model_name}", "{train_data_name}", param_id="{param_id}"),
    output:
        trained_model=trained_model_ckpt("{model_name}", "{train_data_name}", param_id="{param_id}"),
    benchmark:
        benchmark_path("train_models", "{model_name}", train_data="{train_data_name}", device=device, param_id="{param_id}"),
    run:
        train_model(
            wildcards.model_name,
            wildcards.train_data_name,
            output.trained_model,
            device,
            input.hyperparameter_path,
            profiling=False,
            timestamp=timestamp,
            param_id=wildcards.param_id,
        )


rule test_models:
    input:
        trained_model=trained_model_ckpt("{model_name}", "{train_data_name}", "{param_id}"),
        hyperparameter_path=best_model_params("{model_name}", "{train_data_name}", "{param_id}"),
    output:
        tested_model=tested_model_ckpt("{model_name}", "{train_data_name}", "{test_data_name}", param_id="{param_id}"),
    run:
        test_model(
            trained_model_name=wildcards.model_name,
            train_data_name=wildcards.train_data_name,
            trained_model_ckpt=input.trained_model,
            test_data_name=wildcards.test_data_name,
            test_checkpoint=output.tested_model,
            device=device,
            hyperparameter_path=input.hyperparameter_path,
            timestamp=timestamp,
            param_id=wildcards.param_id,
        )


rule create_csvs:
    input:
        tested_model=tested_model_ckpt("{model_name}", "{train_data_name}", "{test_data_name}", "{param_id}"),
        trained_model=trained_model_ckpt("{model_name}", "{train_data_name}", "{param_id}"),
        hyperparameter_path=best_model_params("{model_name}", "{train_data_name}", "{param_id}"),
    output:
        csv_path=csv_log_path("{model_name}", "{train_data_name}", test_data_name="{test_data_name}", param_id="{param_id}", device="{device}", date="{timestamp}"),
    run:
        aggregate_data_to_csv(
            model_name=wildcards.model_name,
            train_data_name=wildcards.train_data_name,
            test_data_name=wildcards.test_data_name,
            device=device,
            timestamp=timestamp,
            param_id=wildcards.param_id,
            n_hyperparameter_trials=n_hyperparameter_trials,
            hyperparameter_path=input.hyperparameter_path,
            trained_model_ckpt=input.trained_model,
            tested_model_ckpt=input.tested_model,
            csv_output_path=output.csv_path,
        )


rule concat_csvs:
    input:
        csv_input_paths=csv_individual_paths,
    output:
        csv_output_path=csv_output_path,
    run:
        concatenate_csvs(
            input.csv_input_paths,
            output.csv_output_path,
        )


rule create_pdfs:
    input:
        csv_output_path=csv_output_path
    output:
        notebook_output_path=notebook_output_path
    run:
        pm.execute_notebook(
            input_path=notebook_input_path,
            output_path=output.notebook_output_path,
        )
