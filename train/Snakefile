rule concat_csvs_step:
    input:
        csv_input_paths=csv_single_paths,
    output:
        csv_output_path=csv_output_path,
    run:
        concatenate_csvs(
            input_csv_paths=input.csv_input_paths,
            output_csv_path=output.csv_output_path,
        )


rule create_pdfs_step:
    input:
        csv_output_path=csv_output_path,
    output:
        notebook_output_path=notebook_output_path,
    run:
        parameters = {
            "output_dir": run_dir,
            "results_dir": f"{run_dir}/result_csvs_and_pdfs",
            "summary_csv_path": input.csv_output_path,
        }
        pm.execute_notebook(
            input_path=notebook_input_path,
            output_path=output.notebook_output_path,
            parameters=parameters,
            report_mode=False,
        )


rule log_metadata_step:
    output:
        config_output_path=config_output_path,
        data_nicknames_output_path=data_nicknames_output_path,
    run:
        with open(config_output_path, "w") as f:
            json.dump(config, f)
        shutil.copy(data_nicknames_path, data_nicknames_output_path)
