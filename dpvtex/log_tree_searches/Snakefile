import os
from glob import glob
from aggregate_treesearch_data import aggregate_treesearch_data

# get config from command line or use default
snakefile_dir = workflow.basedir
default_config_path = os.path.join(snakefile_dir, "config.yaml")
try:
    config_path = os.path.join(snakefile_dir, args[args.index("--configfile") + 1])
except:
    config_path = default_config_path


configfile: config_path


input_dir = config["input_dir"]
dpvt_data_dir = config["dpvt_data_dir"]
larch_build = config["larch_build"]
nicknames = config["nicknames"]
num_replicates = config.get(
    "num_replicates", 3
)  # Default to 3 replicates if not specified


# Get input files
def get_input_files():
    # find all input fastas in provided input directory
    input_files = glob(os.path.join(input_dir, "*/*.fasta"))
    input_files += glob(os.path.join(input_dir, "*/*.fa"))
    input_files += glob(os.path.join(input_dir, "*/*.nexus"))
    input_files += glob(os.path.join(input_dir, "*/*.nex"))
    # Skip files that don't have directory name as basename
    input_files = [
        f for f in input_files if os.path.basename(f) == f.split("/")[-2] + ".fasta"
    ]
    return input_files


treesearch_data_paths = expand(
    os.path.join(dpvt_data_dir, "{basename}_rep{replicate}_tree_search_test.p"),
    basename=[os.path.basename(f).rsplit(".", 1)[0] for f in get_input_files()],
    replicate=range(1, num_replicates + 1),
)

aggregated_treesearch_data_paths = expand(
    os.path.join(dpvt_data_dir, "{basename}_tree_search.p"),
    basename=[os.path.basename(f).rsplit(".", 1)[0] for f in get_input_files()],
)


rule all:
    input:
        treesearch_data_paths,
        aggregated_treesearch_data_paths,
        "nicknames_added.flag",


rule log_mp_tree_search:
    input:
        fasta="{file}.fasta",
    output:
        tree_log="{file}_rep{replicate}_log.trees",
    params:
        seed=lambda wildcards: int(wildcards.replicate) * 100,  # Different seed for each replicate
    shell:
        "Rscript log_mp_tree_search.R -f {input.fasta} -o {output.tree_log} --seed {params.seed}"


rule prepare_larch_input:
    input:
        fasta="{file}.fasta",
    output:
        input_fasta=os.path.join(os.path.dirname("{file}"), "input.fasta"),
    shell:
        "cp {input.fasta} {output.input_fasta}"


rule preprocess_larch:
    input:
        input_fasta=os.path.join(os.path.dirname("{file}"), "input.fasta"),
    output:
        pb=os.path.join(os.path.dirname("{file}"), "output.pb"),
    params:
        output_dir=lambda wildcards, input: os.path.dirname(input.input_fasta),
    shell:
        "snakemake --snakefile ../larch/setup_larch_inputs/convert_fasta_to_larch_input.snakefile "
        "--configfile ../larch/setup_larch_inputs/config.yaml -d {params.output_dir} -c1"


rule run_larch_usher:
    input:
        pb=os.path.join(os.path.dirname("{file}"), "output.pb"),
        txt=os.path.join(os.path.dirname("{file}"), "output.txt"),
        vcf=os.path.join(os.path.dirname("{file}"), "output.vcf"),
    output:
        larch_output=os.path.join(os.path.dirname("{file}"), "larch-output.pb"),
        log=os.path.join(os.path.dirname("{file}"), "log"),
    params:
        larch_build=larch_build,
        output_dir=lambda wildcards, input: os.path.dirname(input.pb),
    shell:
        "cd {params.larch_build} && "
        "./larch-usher -i {input.pb} -r {input.txt} -v {input.vcf} "
        "-o {output.larch_output} -l {output.log} -c 200"


rule compute_labels:
    input:
        larch_output=os.path.join(
            os.path.dirname(input_dir + "/{basename}/{basename}.fasta"),
            "larch-output.pb",
        ),
        tree_log=input_dir + "/{basename}/{basename}_rep{replicate}_log.trees",
        fasta=input_dir + "/{basename}/{basename}.fasta",
    output:
        test_p=os.path.join(
            config["dpvt_data_dir"], "{basename}_rep{replicate}_tree_search_test.p"
        ),
    shell:
        "python create_testing_data.py {input.larch_output} "
        "{output.test_p} {input.tree_log} {input.fasta}"


rule add_to_dataset_nicknames:
    input:
        treesearch_data_paths,
    output:
        touch("nicknames_added.flag"),
    params:
        dpvt_data_dir=dpvt_data_dir,
        nicknames=nicknames,
    shell:
        "python add_to_dataset_nicknames.py {params.dpvt_data_dir} {params.nicknames}"


rule aggregate_all_treesearch_data:
    input:
        filenames = treesearch_data_paths,
    output:
        aggregated_treesearch_data_paths
    run:
        aggregate_treesearch_data(input.filenames)