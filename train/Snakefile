# use defaults where option not in config file
for arg in default_config:
    if arg not in config:
        config[arg] = default_config[arg]
for arg in default_config["hyperparameters"]:
    if arg not in config["hyperparameters"]:
        config["hyperparameters"][arg] = default_config["hyperparameters"][arg]
if not config["use_hyperparameter_optimize"]:
    config["n_hyperparameter_trials"] = 0


# config settings
working_dir = config["working_dir"]
output_dir = config["output_dir"]
data_nicknames_path = config["data_nicknames_path"]
