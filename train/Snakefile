notebook_dict = {os.path.basename(nb):nb for nb in notebook_input_paths}
if len(notebook_dict) != len(notebook_input_paths):
    raise ValueError(f"Duplicate notebook name: all input notebooks in {notebook_input_paths} must have unique names.")


from dpvtex.evaluate_individual_trees import (evaluate_individual_trees, 
