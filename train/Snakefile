            train_data="{train_data_name}",
            param_id="{param_id}",
            device=device,
            timestamp=timestamp,
            output_dir=output_dir,
        ),
    output:
        tested_model=get_tested_model_ckpt(
            model="{model_name}",
            train_data="{train_data_name}",
